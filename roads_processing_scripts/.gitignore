# ============================================================================
# 🚫 GITIGNORE - Networks Notebooks Publication
# ============================================================================

# ============================================================================
# 📦 Python Cache and Bytecode
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ============================================================================
# 📓 Jupyter Notebook Checkpoints
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# 🗄️ Cache and Temporary Files
# ============================================================================
cache/
*.cache
*.tmp
*.temp

# ============================================================================
# 📝 Log Files
# ============================================================================
*.log
logs/

# ============================================================================
# 🔐 Environment and Secrets
# ============================================================================
.env
.env.local
.env.*.local
*.env
secrets.yaml
secrets.yml

# ============================================================================
# 💻 IDE and Editor Files
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# 📊 Large Data Files (optional - uncomment if needed)
# ============================================================================
# *.csv
# *.parquet
# *.graphml
# data/raw/

# ============================================================================
# 🖼️ Output Images (optional - uncomment to exclude)
# ============================================================================
# output.png
# *.png

# ============================================================================
# 📁 Archive (optional - uncomment to exclude from publication)
# ============================================================================
# archive/
